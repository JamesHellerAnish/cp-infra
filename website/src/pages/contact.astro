---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<BaseLayout title="Contact Us — CP Systems Pvt. Ltd." description="Get in touch with CP Systems Pvt Ltd for your infrastructure projects. Located at Pitampura, New Delhi.">
  <Header />

  <div class="page-header">
    <div class="container">
      <h1 class="page-header__title">Contact Us</h1>
      <div class="page-header__breadcrumb">
        <a href="/">Home</a> <span>/</span> <span>Contact</span>
      </div>
    </div>
  </div>

  <section class="section">
    <div class="container">
      <div class="contact-grid">
        <!-- Contact Form -->
        <div class="animate-on-scroll">
          <span class="section-label">Reach Out to Excellence</span>
          <h2 class="section-title">Send Us a Message</h2>
          <p style="margin-bottom: 30px;">Have a project in mind? Fill in the form below and our team will get back to you within 24 hours.</p>

          <form class="contact-form" action="#" method="POST">
            <div class="form-row">
              <div class="form-group">
                <label for="name">Full Name</label>
                <input type="text" id="name" name="name" placeholder="Your Name" required />
              </div>
              <div class="form-group">
                <label for="email">Email Address</label>
                <input type="email" id="email" name="email" placeholder="your@email.com" required />
              </div>
            </div>
            <div class="form-row">
              <div class="form-group">
                <label for="phone">Phone Number</label>
                <input type="tel" id="phone" name="phone" placeholder="+91-XXXXX XXXXX" />
              </div>
              <div class="form-group">
                <label for="subject">Subject</label>
                <input type="text" id="subject" name="subject" placeholder="Project Inquiry" />
              </div>
            </div>
            <div class="form-group">
              <label for="message">Message</label>
              <textarea id="message" name="message" placeholder="Tell us about your project..." required></textarea>
            </div>
            <button type="submit" class="btn btn--gold" style="width: fit-content;">Send Message →</button>
          </form>
        </div>

        <!-- Contact Info -->
        <div class="contact-sidebar animate-on-scroll">
          <div class="contact-info-card">
            <h3>Office Address</h3>
            <div class="contact-info-item">
              <div class="contact-info-icon">📍</div>
              <div>
                <strong>CP Systems Pvt. Ltd.</strong><br/>
                501, Krishna Apra Business Square,<br/>
                Netaji Subhash Place, Pitampura,<br/>
                New Delhi-110034 (INDIA)
              </div>
            </div>

            <div class="contact-info-item">
              <div class="contact-info-icon">📞</div>
              <div>
                <strong>Phone</strong><br/>
                <a href="tel:01140539469">011-40539469 (Landline)</a><br/>
                <a href="tel:+919212150206">+91-9212150206</a><br/>
                <a href="tel:+919819953664">+91-9819953664</a>
              </div>
            </div>

            <div class="contact-info-item">
              <div class="contact-info-icon">✉️</div>
              <div>
                <strong>Email</strong><br/>
                <a href="mailto:cpsystems_ho@cp-infra.in">cpsystems_ho@cp-infra.in</a><br/>
                <a href="mailto:sanjay_cpsystem@cp-infra.in">sanjay_cpsystem@cp-infra.in</a><br/>
                <a href="mailto:info@cp-infra.in">info@cp-infra.in</a>
              </div>
            </div>

            <div class="contact-info-item">
              <div class="contact-info-icon">🌐</div>
              <div>
                <strong>Website</strong><br/>
                <a href="https://cp-infra.in" target="_blank">www.cp-infra.in</a>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <Footer />
</BaseLayout>

<style>
  .contact-grid {
    display: grid;
    grid-template-columns: 1.5fr 1fr;
    gap: 60px;
    align-items: start;
  }

  @media (max-width: 900px) {
    .contact-grid {
      grid-template-columns: 1fr;
      gap: 40px;
    }
  }

  .contact-info-card {
    background: var(--beige-light);
    border-radius: var(--radius-lg);
    padding: 36px;
    border-left: 4px solid var(--gold);
  }

  .contact-info-card h3 {
    font-size: 1.2rem;
    color: var(--navy);
    margin-bottom: 24px;
  }

  .contact-info-item {
    display: flex;
    gap: 16px;
    margin-bottom: 24px;
    font-size: 0.92rem;
    color: var(--dark-text);
    line-height: 1.7;
  }

  .contact-info-icon {
    font-size: 1.3rem;
    flex-shrink: 0;
    margin-top: 2px;
  }

  .contact-info-item a {
    color: var(--navy);
    text-decoration: none;
  }

  .contact-info-item a:hover {
    color: var(--gold-dark);
    text-decoration: underline;
  }
</style>
