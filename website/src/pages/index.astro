---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<BaseLayout title="CP Systems Pvt. Ltd. — Constructing a Better World">
  <Header />

  <!-- Hero Section — Image Collage -->
  <section class="hero">
    <div class="hero__collage">
      <div class="hero__collage-item hero__collage-item--1"><img src="/images/pdf_page_15_img_123.jpg" alt="Badrinath Dham Riverfront" /></div>
      <div class="hero__collage-item hero__collage-item--2"><img src="/images/pdf_page_13_img_112.jpg" alt="Kedarnath Dham Construction" /></div>
      <div class="hero__collage-item hero__collage-item--3"><img src="/images/pdf_page_20_img_142.jpg" alt="Tehri Dam" /></div>
      <div class="hero__collage-item hero__collage-item--4"><img src="/images/pdf_page_18_img_136.jpg" alt="River Dredging Operations" /></div>
      <div class="hero__collage-item hero__collage-item--5"><img src="/images/pdf_fix_p6_img_1.jpg" alt="Bhutan Granite Blocks" /></div>
      <div class="hero__collage-item hero__collage-item--6"><img src="/images/pdf_page_21_img_145.jpg" alt="Hailang Dam VPHEP" /></div>
      <div class="hero__collage-item hero__collage-item--7"><img src="/images/pdf_page_14_img_116.jpg" alt="Kedarnath Building" /></div>
      <div class="hero__collage-item hero__collage-item--8"><img src="/images/pdf_page_9_img_90.jpg" alt="Kekri Mine Operations" /></div>
      <div class="hero__collage-item hero__collage-item--9"><img src="/images/slide_54_img_3.jpg" alt="Baffle Wall Construction" /></div>
      <div class="hero__collage-item hero__collage-item--10"><img src="/images/pdf_page_16_img_127.jpg" alt="Civic Center Badrinath" /></div>
      <div class="hero__collage-item hero__collage-item--11"><img src="/images/pdf_fix_p10_img_5.jpg" alt="White Galaxy Granite" /></div>
      <div class="hero__collage-item hero__collage-item--12"><img src="/images/pdf_page_19_img_138.jpg" alt="Tehri Tunnel Repair" /></div>
    </div>
    <div class="hero__overlay"></div>
    <div class="container hero__content">
      <div class="hero__badge">🏆 Recipients of Udyog Ratan Award & Excellence Award</div>
      <h1 class="hero__title">
        Constructing a<br/><span>Better World</span>
      </h1>
      <p class="hero__subtitle">
        Over 3 decades of delivering complex infrastructure projects across India and beyond — from hydropower dams to riverfront development, mining to civil construction.
      </p>
      <div class="hero__actions">
        <a href="/about/" class="btn btn--gold">Discover Our Story</a>
        <a href="/contact/" class="btn btn--outline">Get In Touch</a>
      </div>
    </div>
  </section>

  <!-- Legacy Section -->
  <section class="section">
    <div class="container">
      <div class="content-block animate-on-scroll">
        <div>
          <span class="section-label">A Legacy of Transformation</span>
          <h2 class="section-title">Over 3 Decades of Infra-Excellence</h2>
          <p>
            C P Systems Pvt. Ltd., established in 1999, is not just a company — it is an institution built on a foundation of innovation, ingenuity, and purpose. With a firm belief in meaningful and timely project execution, CPS stands out for its creative approach, technical excellence, and unwavering commitment to quality.
          </p>
          <br/>
          <p>
            After gaining experience and expertise, and profitably reaping the fruits of diversification, the portfolio of CPS has a variety in terms of both the activities undertaken and the clients served — Government & Semi Government Departments, Public Sector Undertakings, Turnkey Projects Operators and Promoters & Builders.
          </p>
          <br/>
          <a href="/about/" class="btn btn--navy" style="margin-top: 12px;">Learn More →</a>
        </div>
        <div class="content-block__image">
          <img src="/images/pdf_page_2_img_1.jpg" alt="MD with King of Bhutan" />
        </div>
      </div>
    </div>
  </section>

  <!-- Stats Section -->
  <section class="section section--navy">
    <div class="container">
      <div class="stats-grid">
        <div class="stat-item">
          <div class="stat-number" data-counter="25" data-suffix="+">0</div>
          <div class="stat-label">Years of Experience</div>
        </div>
        <div class="stat-item">
          <div class="stat-number" data-counter="143" data-prefix="₹" data-suffix=" Cr">0</div>
          <div class="stat-label">Annual Turnover (FY 2024-25)</div>
        </div>
        <div class="stat-item">
          <div class="stat-number" data-counter="50" data-suffix="+">0</div>
          <div class="stat-label">Major Projects</div>
        </div>
        <div class="stat-item">
          <div class="stat-number" data-counter="154" data-suffix="%">0</div>
          <div class="stat-label">Growth Rate</div>
        </div>
      </div>
    </div>
  </section>

  <!-- Expertise Section -->
  <section class="section section--beige">
    <div class="container">
      <span class="section-label">Our Expertise</span>
      <h2 class="section-title">Comprehensive Infrastructure Solutions</h2>
      <p class="section-desc" style="margin-bottom: 40px;">
        Encompassing diverse areas of construction pan India and beyond, CPS delivers end-to-end infrastructure solutions powered by innovation and commitment.
      </p>

      <div class="grid grid--3">
        <div class="service-card animate-on-scroll">
          <div class="service-card__icon">🏗️</div>
          <h4 class="service-card__title">Civil & Mechanical Works</h4>
          <p class="service-card__desc">Riverfront development, pedestrian bridges, civic center buildings, and pilgrimage accommodation — as executed at Badrinath Dham & Kedarnath Dham.</p>
        </div>
        <div class="service-card animate-on-scroll">
          <div class="service-card__icon">💧</div>
          <h4 class="service-card__title">Hydropower & River Dredging</h4>
          <p class="service-card__desc">Multi-phase river dredging, baffle wall construction across flowing rivers, and hydropower infrastructure — as executed at Tehri Dam Phase 1 & 2.</p>
        </div>
        <div class="service-card animate-on-scroll">
          <div class="service-card__icon">⛏️</div>
          <h4 class="service-card__title">Mining & Exploration</h4>
          <p class="service-card__desc">Granite quarrying, processing, and premium stone products — operating mines in Bhutan (85 acres) and Kekri, Rajasthan (1 Hectare).</p>
        </div>
        <div class="service-card animate-on-scroll">
          <div class="service-card__icon">🔩</div>
          <h4 class="service-card__title">Drilling & Grouting</h4>
          <p class="service-card__desc">Consolidation grouting with microfine cement, PU grouting, colloidal silica injection, and micro piling — as executed at Tehri HRT/TRT and VPHEP.</p>
        </div>
        <div class="service-card animate-on-scroll">
          <div class="service-card__icon">🧪</div>
          <h4 class="service-card__title">Epoxy & Repair Works</h4>
          <p class="service-card__desc">Epoxy mortar application, underwater epoxy treatment, seal coats, and surface repair — as executed at Tehri Intake Structures and HRT #3 & #4.</p>
        </div>
        <div class="service-card animate-on-scroll">
          <div class="service-card__icon">🏛️</div>
          <h4 class="service-card__title">Dam & Tunnel Rehabilitation</h4>
          <p class="service-card__desc">Gate groove restoration, spillway repair, tunnel lining, and structural strengthening — as executed at Hailang Dam VPHEP and Maneri Bhali Dam.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Key Projects Section -->
  <section class="section">
    <div class="container">
      <span class="section-label">Projects Showcase</span>
      <h2 class="section-title">Key Projects</h2>
      <p class="section-desc" style="margin-bottom: 40px;">
        Our track record speaks for itself — from sacred pilgrimage sites to massive hydropower dams, every project bears the stamp of quality and commitment.
      </p>

      <div class="grid grid--3">
        <a href="/projects/badrinath-dham/" class="project-card animate-on-scroll">
          <img src="/images/pdf_page_15_img_123.jpg" alt="Badrinath Dham" class="project-card__img" />
          <div class="project-card__overlay">
            <span class="project-card__tag">Hydropower</span>
            <h3 class="project-card__title">Badrinath Dham</h3>
            <p class="project-card__desc">Riverfront development, pedestrian bridge, and civic center at Shri Badrinath Dham along the Alaknanda River.</p>
            <span class="project-card__link">View Project →</span>
          </div>
        </a>

        <a href="/projects/kedarnath-dham/" class="project-card animate-on-scroll">
          <img src="/images/pdf_page_13_img_112.jpg" alt="Kedarnath Dham" class="project-card__img" />
          <div class="project-card__overlay">
            <span class="project-card__tag">Civil Works</span>
            <h3 class="project-card__title">Kedarnath Dham</h3>
            <p class="project-card__desc">Construction of Pilgrim Accommodation Block at Shri Kedarnath Dham in challenging Himalayan terrain.</p>
            <span class="project-card__link">View Project →</span>
          </div>
        </a>

        <a href="/projects/tehri-dam/" class="project-card animate-on-scroll">
          <img src="/images/pdf_page_20_img_142.jpg" alt="Tehri Dam" class="project-card__img" />
          <div class="project-card__overlay">
            <span class="project-card__tag">Hydropower</span>
            <h3 class="project-card__title">Tehri Dam</h3>
            <p class="project-card__desc">River dredging, baffle wall construction, HRT/TRT repair, and epoxy treatment at India's tallest dam.</p>
            <span class="project-card__link">View Project →</span>
          </div>
        </a>

        <a href="/projects/hailang-dam/" class="project-card animate-on-scroll">
          <img src="/images/pdf_page_21_img_145.jpg" alt="Hailang Dam" class="project-card__img" />
          <div class="project-card__overlay">
            <span class="project-card__tag">Hydropower</span>
            <h3 class="project-card__title">Hailang Dam (VPHEP)</h3>
            <p class="project-card__desc">Restoration of gate groove in diversion tunnel at Vishnugadh Pipalkoti Hydroelectric Project.</p>
            <span class="project-card__link">View Project →</span>
          </div>
        </a>

        <a href="/projects/bhutan-mine/" class="project-card animate-on-scroll">
          <img src="/images/pdf_fix_p6_img_1.jpg" alt="Bhutan Mine" class="project-card__img" />
          <div class="project-card__overlay">
            <span class="project-card__tag">Mining</span>
            <h3 class="project-card__title">Bhutan Granite Mine</h3>
            <p class="project-card__desc">85-acre granite mine in Wangdue, Bhutan with 8 Million MT reserves — home to CP-DRUK White Galaxy.</p>
            <span class="project-card__link">View Project →</span>
          </div>
        </a>

        <a href="/projects/kekri-mine/" class="project-card animate-on-scroll">
          <img src="/images/pdf_page_9_img_90.jpg" alt="Kekri Mine" class="project-card__img" />
          <div class="project-card__overlay">
            <span class="project-card__tag">Mining</span>
            <h3 class="project-card__title">Kekri Granite Mine</h3>
            <p class="project-card__desc">1 Hectare granite mine in Kekri, Rajasthan with 1 Million MT reserves of premium quality granite.</p>
            <span class="project-card__link">View Project →</span>
          </div>
        </a>
      </div>
    </div>
  </section>

  <!-- Presence Section -->
  <section class="section section--navy" style="background: linear-gradient(135deg, var(--navy) 0%, var(--navy-dark) 100%);">
    <div class="container" style="text-align: center;">
      <span class="section-label">Our Presence</span>
      <h2 class="section-title" style="color: var(--white);">Pan India & Beyond</h2>
      <p class="section-desc" style="margin: 0 auto 40px; color: rgba(255,255,255,0.7); text-align: center;">
        From the sacred sites of Uttarakhand to the granite mines of Bhutan, CPS has established its footprint across diverse geographies, executing infrastructure projects in challenging terrains and extreme conditions.
      </p>
      <div style="display: flex; justify-content: center; flex-wrap: wrap; gap: 30px; margin-top: 30px;">
        <div style="text-align: center; padding: 20px 30px;">
          <div style="font-size: 2rem; font-weight: 900; color: var(--gold);">Uttarakhand</div>
          <div style="font-size: 0.85rem; color: rgba(255,255,255,0.6);">Tehri, Badrinath, Kedarnath, VPHEP</div>
        </div>
        <div style="text-align: center; padding: 20px 30px;">
          <div style="font-size: 2rem; font-weight: 900; color: var(--gold);">Rajasthan</div>
          <div style="font-size: 0.85rem; color: rgba(255,255,255,0.6);">Kekri Granite Mine</div>
        </div>
        <div style="text-align: center; padding: 20px 30px;">
          <div style="font-size: 2rem; font-weight: 900; color: var(--gold);">Bhutan</div>
          <div style="font-size: 0.85rem; color: rgba(255,255,255,0.6);">Wangdue Granite Mine</div>
        </div>
        <div style="text-align: center; padding: 20px 30px;">
          <div style="font-size: 2rem; font-weight: 900; color: var(--gold);">Delhi NCR</div>
          <div style="font-size: 0.85rem; color: rgba(255,255,255,0.6);">Corporate Headquarters</div>
        </div>
      </div>
    </div>
  </section>

  <!-- Financial Growth Section -->
  <section class="section">
    <div class="container" style="text-align: center;">
      <span class="section-label">Our Growth</span>
      <h2 class="section-title">Financial Growth Trajectory</h2>
      <p class="section-desc" style="margin: 0 auto 40px; text-align: center;">
        Driven by new markets, strong partnerships, skilled teams, and reliable quality — CPS has achieved exceptional growth year over year.
      </p>

      <div class="growth-chart animate-on-scroll">
        <div class="growth-bar">
          <div class="growth-bar__value">₹24.3 Cr</div>
          <div class="growth-bar__bar" style="height: 80px;"></div>
          <div class="growth-bar__year">FY 2022-23</div>
        </div>
        <div class="growth-bar">
          <div class="growth-bar__value">₹61.9 Cr</div>
          <div class="growth-bar__bar" style="height: 160px;"></div>
          <div class="growth-bar__year">FY 2023-24</div>
        </div>
        <div class="growth-bar">
          <div class="growth-bar__value">₹143 Cr</div>
          <div class="growth-bar__bar" style="height: 280px;"></div>
          <div class="growth-bar__year">FY 2024-25</div>
        </div>
      </div>

      <div style="display: flex; gap: 40px; justify-content: center; margin-top: 30px; flex-wrap: wrap;">
        <div style="text-align: center;">
          <div style="font-size: 1.5rem; font-weight: 800; color: var(--navy);">154.7%</div>
          <div style="font-size: 0.8rem; color: var(--grey-text);">Growth FY22-23 → FY23-24</div>
        </div>
        <div style="text-align: center;">
          <div style="font-size: 1.5rem; font-weight: 800; color: var(--navy);">130.9%</div>
          <div style="font-size: 0.8rem; color: var(--grey-text);">Growth FY23-24 → FY24-25</div>
        </div>
      </div>
    </div>
  </section>

  <!-- Contact CTA Section -->
  <section class="section section--navy">
    <div class="container" style="text-align: center;">
      <span class="section-label">Get in Touch</span>
      <h2 class="section-title" style="color: var(--white);">Reach Out to Excellence</h2>
      <p style="color: rgba(255,255,255,0.7); max-width: 600px; margin: 0 auto 30px; font-size: 1.05rem;">
        Ready to discuss your next infrastructure project? Our team of experienced engineers and managers is here to deliver excellence.
      </p>
      <div style="display: flex; gap: 16px; justify-content: center; flex-wrap: wrap;">
        <a href="/contact/" class="btn btn--gold">Contact Us</a>
        <a href="tel:+919212150206" class="btn btn--outline">📞 Call Now</a>
      </div>
    </div>
  </section>

  <Footer />
</BaseLayout>
