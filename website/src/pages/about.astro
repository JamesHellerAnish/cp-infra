---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<BaseLayout title="About Us — CP Systems Pvt. Ltd." description="Learn about CP Systems Pvt Ltd - our story, recognition, vision, and the expert team behind 3 decades of infrastructure excellence.">
  <Header />

  <!-- Page Header -->
  <div class="page-header">
    <div style="position: absolute; inset: 0; z-index: 0;">
      <div class="hero__collage" style="height: 100vh; position: absolute; inset: 0;">
        <div class="hero__collage-item hero__collage-item--1"><img src="/images/pdf_page_15_img_123.jpg" alt="Badrinath Dham Riverfront" /></div>
        <div class="hero__collage-item hero__collage-item--2"><img src="/images/pdf_page_13_img_112.jpg" alt="Kedarnath Dham Construction" /></div>
        <div class="hero__collage-item hero__collage-item--3"><img src="/images/pdf_page_20_img_142.jpg" alt="Tehri Dam" /></div>
        <div class="hero__collage-item hero__collage-item--4"><img src="/images/pdf_page_18_img_136.jpg" alt="River Dredging Operations" /></div>
        <div class="hero__collage-item hero__collage-item--5"><img src="/images/pdf_fix_p6_img_1.jpg" alt="Bhutan Granite Blocks" /></div>
        <div class="hero__collage-item hero__collage-item--6"><img src="/images/pdf_page_21_img_145.jpg" alt="Hailang Dam VPHEP" /></div>
        <div class="hero__collage-item hero__collage-item--7"><img src="/images/pdf_page_14_img_116.jpg" alt="Kedarnath Building" /></div>
        <div class="hero__collage-item hero__collage-item--8"><img src="/images/pdf_page_9_img_90.jpg" alt="Kekri Mine Operations" /></div>
        <div class="hero__collage-item hero__collage-item--9"><img src="/images/slide_54_img_3.jpg" alt="Baffle Wall Construction" /></div>
        <div class="hero__collage-item hero__collage-item--10"><img src="/images/pdf_page_16_img_127.jpg" alt="Civic Center Badrinath" /></div>
        <div class="hero__collage-item hero__collage-item--11"><img src="/images/pdf_fix_p10_img_5.jpg" alt="White Galaxy Granite" /></div>
        <div class="hero__collage-item hero__collage-item--12"><img src="/images/pdf_page_19_img_138.jpg" alt="Tehri Tunnel Repair" /></div>
      </div>
    </div>
    <div class="page-header__overlay"></div>
    
    <div class="container">
      <h1 class="page-header__title">About Us</h1>
      <div class="page-header__breadcrumb">
        <a href="/">Home</a> <span>/</span> <span>About Us</span>
      </div>
    </div>
  </div>

  <!-- Our Story -->
  <section class="section">
    <div class="container">
      <div class="content-block animate-on-scroll">
        <div>
          <span class="section-label">Our Story</span>
          <h2 class="section-title">Built on Innovation, Ingenuity & Purpose</h2>
          <p>
            CPS is not just a company; it is an institution built on a foundation of innovation, ingenuity, and purpose. With a firm belief in meaningful and timely project execution, CPS stands out for its creative approach, technical excellence, and unwavering commitment to quality.
          </p>
          <br/>
          <p>
            We take pride in completing complex infrastructure projects with a focus on innovation and client satisfaction. Our work is not only defined by what we build but by how we build it — with integrity, precision, and a forward-thinking mindset.
          </p>
          <br/>
          <p>
            In addition to project execution, CPS is actively involved in the exploration and advancement of Civil and Structural Design, continually expanding its capabilities through strategic diversification. This progressive outlook has led to our successful foray into Turnkey Project Execution, reflecting our capacity to deliver end-to-end infrastructure solutions.
          </p>
        </div>
        <div class="content-block__image">
          <img src="/images/pdf_page_2_img_3.png" alt="CP Systems Project Infrastructure" />
        </div>
      </div>
    </div>
  </section>

  <!-- Recognition -->
  <section class="section section--beige">
    <div class="container">
      <div class="content-block content-block--reverse animate-on-scroll">
        <div>
          <span class="section-label">Recognition</span>
          <h2 class="section-title">Nationally Recognized Excellence</h2>
          <p>
            Our dedication to excellence has been recognized nationally with the <strong>"Udyog Ratan Award"</strong> and <strong>"Excellence Award"</strong> in 2000–2001, reinforcing our reputation as a reliable and visionary partner in the infrastructure sector.
          </p>
          <br/>
          <p>
            At the core of CPS lies a team of highly skilled and experienced professionals. The strength of our workforce is reflected in its versatility of expertise, ranging from Civil, Anti-Corrosive, Mechanical, and Electrical Works Execution. Our team members bring with them a wealth of technical and practical knowledge, gained through years of service with leading infrastructure companies.
          </p>
          <br/>
          <p>
            We attribute our success to the exceptional caliber of our personnel, many of whom have been associated with top-tier organizations, shaping the infrastructure development map of the nation.
          </p>
        </div>
        <div class="content-block__image">
          <img src="/images/pdf_page_2_img_1.jpg" alt="MD with King of Bhutan" />
        </div>
      </div>
    </div>
  </section>

  <!-- Vision & Growth -->
  <section class="section">
    <div class="container" style="text-align: center;">
      <span class="section-label" style="justify-content: center;">Our Vision</span>
      <h2 class="section-title">Delivering Exceptional Value</h2>
      <p class="section-desc" style="margin: 0 auto 40px; text-align: center;">
        The vision of CPS is to attain maximum heights in the industry — to become an industry leader delivering exceptional value through innovation, integrity, and excellence.
      </p>

      <div class="grid grid--4" style="margin-top: 40px;">
        <div class="service-card animate-on-scroll">
          <div class="service-card__icon">🌎</div>
          <h4 class="service-card__title">New Markets</h4>
          <p class="service-card__desc">Expanding reach to new geographies and sectors</p>
        </div>
        <div class="service-card animate-on-scroll">
          <div class="service-card__icon">🤝</div>
          <h4 class="service-card__title">Strong Partnerships</h4>
          <p class="service-card__desc">Growing together with clients and partners</p>
        </div>
        <div class="service-card animate-on-scroll">
          <div class="service-card__icon">👷</div>
          <h4 class="service-card__title">Skilled Team</h4>
          <p class="service-card__desc">Powered by experienced professionals</p>
        </div>
        <div class="service-card animate-on-scroll">
          <div class="service-card__icon">✅</div>
          <h4 class="service-card__title">Reliable Quality</h4>
          <p class="service-card__desc">Trusted always for timely, quality delivery</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Leadership -->
  <section class="section section--navy">
    <div class="container" style="text-align: center;">
      <span class="section-label">Leadership</span>
      <h2 class="section-title" style="color: var(--white);">Spearheaded by Vision</h2>
      <p style="color: rgba(255,255,255,0.7); max-width: 700px; margin: 0 auto 40px; font-size: 1.05rem;">
        Under the leadership of <strong style="color: var(--gold);">Mr. Sanjay Shandilya, CMD</strong>, CP Systems has grown from a specialized contractor to a multi-faceted infrastructure company operating across India and in Bhutan.
      </p>
      <div class="content-block__image" style="max-width: 500px; margin: 0 auto;">
        <img src="/images/pdf_page_2_img_2.jpg" alt="Udyog Ratan Award" style="border-radius: 12px;" />
      </div>
      <p style="color: rgba(255,255,255,0.5); margin-top: 16px; font-size: 0.85rem;">
        Udyog Rattan Award and Excellence Award being presented to Mr. Sanjay Shandilya, Managing Director, CP Systems Pvt. Ltd.
      </p>
    </div>
  </section>

  <!-- CTA -->
  <section class="section" style="text-align: center;">
    <div class="container">
      <h2 class="section-title">Ready to Build Together?</h2>
      <p class="section-desc" style="margin: 0 auto 30px; text-align: center;">
        Partner with CP Systems for your next infrastructure project. Our experience across diverse sectors and geographies ensures reliable, timely execution.
      </p>
      <a href="/contact/" class="btn btn--gold">Get In Touch →</a>
    </div>
  </section>

  <Footer />
</BaseLayout>
