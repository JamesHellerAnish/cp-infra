---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
---

<BaseLayout title="Hydropower & River Dredging — CP Systems" description="CP Systems expertise in hydropower dam rehabilitation, river dredging, baffle wall construction, tunnel repair, and grouting across major Indian projects.">
  <Header />

  <div class="page-header">
    <div class="container">
      <h1 class="page-header__title">Hydropower & River Dredging</h1>
      <div class="page-header__breadcrumb">
        <a href="/">Home</a> <span>/</span> <a href="#">Speciality</a> <span>/</span> <span>Hydropower</span>
      </div>
    </div>
  </div>

  <!-- Intro -->
  <section class="section">
    <div class="container">
      <div class="content-block animate-on-scroll">
        <div>
          <span class="section-label">Preserving the Ecosystem</span>
          <h2 class="section-title">Hydropower & Dam Infrastructure</h2>
          <p>
            CPS has a proven track record in executing a wide range of technically demanding and time-sensitive hydropower infrastructure projects. Our expertise spans dam and tunnel rehabilitation, river dredging, baffle wall construction, drilling & grouting, shot-creting, slope stabilization, anchoring, micro piling, and various chemical treatments.
          </p>
          <br/>
          <p>
            Our dedicated team of engineers and workforce has successfully delivered projects in the most challenging terrains — working with continuous water flow, extreme weather, and strict safety requirements.
          </p>
        </div>
        <div class="content-block__image">
          <img src="/images/pdf_page_18_img_136.jpg" alt="Hydropower Work at Tehri" />
        </div>
      </div>
    </div>
  </section>

  <!-- Materials & Technologies -->
  <section class="section section--beige">
    <div class="container" style="text-align: center;">
      <span class="section-label" style="justify-content: center;">Materials & Technologies</span>
      <h2 class="section-title">Advanced Solutions for Complex Challenges</h2>
      <div class="grid grid--3" style="margin-top: 40px;">
        <div class="service-card animate-on-scroll">
          <div class="service-card__icon">🏗️</div>
          <h4 class="service-card__title">Ordinary Portland Cement</h4>
          <p class="service-card__desc">Standard grouting and structural repair applications</p>
        </div>
        <div class="service-card animate-on-scroll">
          <div class="service-card__icon">🔬</div>
          <h4 class="service-card__title">Micro Fine Cement</h4>
          <p class="service-card__desc">High-penetration grouting for fine cracks and joints</p>
        </div>
        <div class="service-card animate-on-scroll">
          <div class="service-card__icon">💎</div>
          <h4 class="service-card__title">Colloidal Silica</h4>
          <p class="service-card__desc">Ultra-fine sealing for waterproofing applications</p>
        </div>
        <div class="service-card animate-on-scroll">
          <div class="service-card__icon">🧪</div>
          <h4 class="service-card__title">Polyurethanes (PU)</h4>
          <p class="service-card__desc">Water stop and structural injection grouting</p>
        </div>
        <div class="service-card animate-on-scroll">
          <div class="service-card__icon">🔧</div>
          <h4 class="service-card__title">Epoxy Mortar & Grout</h4>
          <p class="service-card__desc">High-strength repair of concrete surfaces and joints</p>
        </div>
        <div class="service-card animate-on-scroll">
          <div class="service-card__icon">🛡️</div>
          <h4 class="service-card__title">PVC Membranes</h4>
          <p class="service-card__desc">Waterproofing barrier systems for tunnel linings</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Featured Projects -->
  <section class="section">
    <div class="container">
      <span class="section-label">Featured Projects</span>
      <h2 class="section-title">Hydropower Portfolio</h2>

      <div class="grid grid--3" style="margin-top: 40px;">
        <a href="/projects/badrinath-dham/" class="project-card animate-on-scroll">
          <img src="/images/pdf_page_15_img_123.jpg" alt="Badrinath Dham" class="project-card__img" />
          <div class="project-card__overlay">
            <span class="project-card__tag">Riverfront</span>
            <h3 class="project-card__title">Badrinath Dham</h3>
            <p class="project-card__desc">Riverfront development and pedestrian bridge at Shri Badrinath Dham</p>
            <span class="project-card__link">View Details →</span>
          </div>
        </a>

        <a href="/projects/tehri-dam/" class="project-card animate-on-scroll">
          <img src="/images/pdf_page_20_img_142.jpg" alt="Tehri Dam" class="project-card__img" />
          <div class="project-card__overlay">
            <span class="project-card__tag">Dam</span>
            <h3 class="project-card__title">Tehri Dam</h3>
            <p class="project-card__desc">River dredging, baffle wall, HRT/TRT repair at India's tallest dam</p>
            <span class="project-card__link">View Details →</span>
          </div>
        </a>

        <a href="/projects/hailang-dam/" class="project-card animate-on-scroll">
          <img src="/images/pdf_page_21_img_145.jpg" alt="Hailang Dam" class="project-card__img" />
          <div class="project-card__overlay">
            <span class="project-card__tag">Tunnel</span>
            <h3 class="project-card__title">Hailang Dam (VPHEP)</h3>
            <p class="project-card__desc">Gate groove restoration in diversion tunnel at VPHEP</p>
            <span class="project-card__link">View Details →</span>
          </div>
        </a>
      </div>
    </div>
  </section>

  <!-- Executed Works List -->
  <section class="section section--navy">
    <div class="container">
      <span class="section-label">Complete Portfolio</span>
      <h2 class="section-title" style="color: var(--white);">Executed & Ongoing Works</h2>
      <div class="grid grid--2" style="margin-top: 30px;">
        <ul class="scope-list" style="color: rgba(255,255,255,0.8);">
          <li>Riverfront Development at Shri Badrinath Dham</li>
          <li>River Dredging & Baffle Wall at Tehri PSP (Phase 1 & 2)</li>
          <li>HRT/TRT Repair by Epoxy Mortar at Tehri PSP</li>
          <li>Epoxy Treatment at Intake Structures 1 & 2 at Tehri HPP</li>
          <li>Gate Groove Restoration at VPHEP Diversion Tunnel</li>
          <li>PU/MFC/Colloidal Silica Grouting at VPHEP Pipalkoti</li>
        </ul>
        <ul class="scope-list" style="color: rgba(255,255,255,0.8);">
          <li>Slope Stabilization & Grouting at Koteshwar HEP</li>
          <li>Spillway & Roller Bucket Repair at Maneri Bhali Stage-I</li>
          <li>Repair & Rectification of RC Dam at Tapovan VPHEP</li>
          <li>HRT Repair at NHPC Sewa II HEP, J&K</li>
          <li>Surge Shaft Swirling Device Repair at Tehri HPP</li>
          <li>PU Grouting at Chamera-III HE Project</li>
        </ul>
      </div>
    </div>
  </section>

  <Footer />
</BaseLayout>
