---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
---

<BaseLayout title="Mining & Exploration — CP Systems" description="CP Systems granite mining operations in Bhutan and Rajasthan. Premium CP-DRUK White Galaxy, Steel Grey, Black Galaxy, Red Galaxy granite collection.">
  <Header />

  <div class="page-header">
    <div class="container">
      <h1 class="page-header__title">Mining & Exploration</h1>
      <div class="page-header__breadcrumb">
        <a href="/">Home</a> <span>/</span> <a href="#">Speciality</a> <span>/</span> <span>Mining</span>
      </div>
    </div>
  </div>

  <!-- Intro -->
  <section class="section">
    <div class="container">
      <div class="content-block animate-on-scroll">
        <div>
          <span class="section-label">Tapping into Rich Resources</span>
          <h2 class="section-title">Mining & Granite Exploration</h2>
          <p>
            CPS's Mining and Exploration division uncovers valuable resources through precise surveying, drilling, and excavation, supporting sustainable development and industrial growth. With active operations in Bhutan and Rajasthan, CPS produces premium-grade granite for flooring, countertops, facades, and custom applications.
          </p>
          <br/>
          <p>
            Our subsidiary company, <strong>Karma CP Systems Private Limited</strong>, operates the Bhutan granite mine — one of the largest white granite reserves in the region.
          </p>
        </div>
        <div class="content-block__image">
          <img src="/images/pdf_fix_p6_img_1.jpg" alt="Bhutan Mine" />
        </div>
      </div>
    </div>
  </section>

  <!-- Mines -->
  <section class="section section--beige">
    <div class="container">
      <span class="section-label">Our Mines</span>
      <h2 class="section-title">Active Mining Operations</h2>
      <div class="grid grid--2" style="margin-top: 40px;">
        <a href="/projects/bhutan-mine/" class="project-card animate-on-scroll" style="height: 360px;">
          <img src="/images/pdf_fix_p6_img_1.jpg" alt="Bhutan Mine" class="project-card__img" />
          <div class="project-card__overlay">
            <span class="project-card__tag">Bhutan</span>
            <h3 class="project-card__title">Bhutan Granite Mine, Wangdue</h3>
            <p class="project-card__desc">85 Acre — 8 Million MT Reserves — CP-DRUK White Galaxy Granite</p>
            <span class="project-card__link">View Details →</span>
          </div>
        </a>

        <a href="/projects/kekri-mine/" class="project-card animate-on-scroll" style="height: 360px;">
          <img src="/images/pdf_page_9_img_90.jpg" alt="Kekri Mine" class="project-card__img" />
          <div class="project-card__overlay">
            <span class="project-card__tag">Rajasthan</span>
            <h3 class="project-card__title">Kekri Granite Mine, Rajasthan</h3>
            <p class="project-card__desc">1 Hectare — 1 Million MT Reserves — Steel Grey, Black & Red Galaxy</p>
            <span class="project-card__link">View Details →</span>
          </div>
        </a>
      </div>
    </div>
  </section>

  <!-- Premium Granite Collection -->
  <section class="section">
    <div class="container" style="text-align: center;">
      <span class="section-label" style="justify-content: center;">Premium Collection</span>
      <h2 class="section-title">Our Granite Collection</h2>
      <p class="section-desc" style="margin: 0 auto 40px; text-align: center;">
        Explore our exquisite selection of natural granite, handpicked for quality and beauty. Perfect for flooring, countertops, facades, and customized applications.
      </p>

      <div class="grid grid--4" style="margin-top: 30px;">
        <div class="granite-card animate-on-scroll">
          <img src="/images/pdf_fix_p10_img_5.jpg" alt="CP-DRUK White Galaxy" class="granite-card__img" />
          <div class="granite-card__info">
            <div class="granite-card__name">CP-DRUK White Galaxy</div>
            <div class="granite-card__location">Bhutan</div>
          </div>
        </div>
        <div class="granite-card animate-on-scroll">
          <img src="/images/pdf_page_10_img_100.jpg" alt="Steel Grey" class="granite-card__img" />
          <div class="granite-card__info">
            <div class="granite-card__name">Steel Grey</div>
            <div class="granite-card__location">Kekri, Rajasthan</div>
          </div>
        </div>
        <div class="granite-card animate-on-scroll">
          <img src="/images/pdf_page_11_img_102.jpg" alt="Red Galaxy" class="granite-card__img" />
          <div class="granite-card__info">
            <div class="granite-card__name">Red Galaxy</div>
            <div class="granite-card__location">Kekri, Rajasthan</div>
          </div>
        </div>
        <div class="granite-card animate-on-scroll">
          <img src="/images/pdf_page_11_img_103.jpg" alt="Black Galaxy" class="granite-card__img" />
          <div class="granite-card__info">
            <div class="granite-card__name">Black Galaxy</div>
            <div class="granite-card__location">Kekri, Rajasthan</div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Crafted Products -->
  <section class="section section--navy">
    <div class="container" style="text-align: center;">
      <span class="section-label">Artisanal Products</span>
      <h2 class="section-title" style="color: var(--white);">Stone Sculptures & Crafted Products</h2>
      <p style="color: rgba(255,255,255,0.7); max-width: 650px; margin: 0 auto 30px;">
        Experience spiritual and artistic elegance with our handcrafted sculptures. Ideal for homes, gardens, meditation zones, and cultural spaces. Custom stone carvings inspired by nature and tradition.
      </p>
      <div class="grid grid--4" style="margin-top: 30px;">
        <div class="granite-card animate-on-scroll">
          <img src="/images/pdf_page_7_img_78.jpg" alt="Crafted Product 1" class="granite-card__img" />
          <div class="granite-card__info">
            <div class="granite-card__name">Buddha Statues</div>
          </div>
        </div>
        <div class="granite-card animate-on-scroll">
          <img src="/images/pdf_page_7_img_79.jpg" alt="Crafted Product 2" class="granite-card__img" />
          <div class="granite-card__info">
            <div class="granite-card__name">Spiritual Icons</div>
          </div>
        </div>
        <div class="granite-card animate-on-scroll">
          <img src="/images/pdf_page_7_img_80.jpg" alt="Crafted Product 3" class="granite-card__img" />
          <div class="granite-card__info">
            <div class="granite-card__name">Custom Designs</div>
          </div>
        </div>
        <div class="granite-card animate-on-scroll">
          <img src="/images/pdf_page_7_img_81.jpg" alt="Crafted Product 4" class="granite-card__img" />
          <div class="granite-card__info">
            <div class="granite-card__name">Bespoke Art</div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <Footer />
</BaseLayout>
