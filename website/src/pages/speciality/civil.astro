---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
---

<BaseLayout title="Civil & Mechanical Works — CP Systems" description="CP Systems civil and mechanical construction expertise: buildings, structures, fabrication, pilgrimage sites, thermal power, highways, and industrial projects.">
  <Header />

  <div class="page-header">
    <div class="container">
      <h1 class="page-header__title">Civil & Mechanical Works</h1>
      <div class="page-header__breadcrumb">
        <a href="/">Home</a> <span>/</span> <a href="#">Speciality</a> <span>/</span> <span>Civil & Mechanical</span>
      </div>
    </div>
  </div>

  <section class="section">
    <div class="container">
      <div class="content-block animate-on-scroll">
        <div>
          <span class="section-label">Building for India</span>
          <h2 class="section-title">Civil & Mechanical Construction</h2>
          <p>
            CPS delivers robust structures, efficient utilities, and integrated systems with unmatched durability and safety. Our expertise covers all aspects of civil construction — from foundation to finishing — including structural steel fabrication, reinforcement work, formwork, concreting, and MEP services.
          </p>
          <br/>
          <p>
            Our team has delivered landmark projects at sacred pilgrimage sites under extreme terrain and weather conditions, as well as industrial complexes, treatment plants, and highway infrastructure across India.
          </p>
        </div>
        <div class="content-block__image">
          <img src="/images/pdf_page_14_img_116.jpg" alt="Kedarnath Construction" />
        </div>
      </div>
    </div>
  </section>

  <!-- Capabilities -->
  <section class="section section--beige">
    <div class="container" style="text-align: center;">
      <span class="section-label" style="justify-content: center;">Our Capabilities</span>
      <h2 class="section-title">Core Competencies</h2>
      <div class="grid grid--3" style="margin-top: 40px;">
        <div class="service-card animate-on-scroll">
          <div class="service-card__icon">🧱</div>
          <h4 class="service-card__title">Concreting</h4>
          <p class="service-card__desc">High-performance concrete work including underwater and above-water applications</p>
        </div>
        <div class="service-card animate-on-scroll">
          <div class="service-card__icon">🏢</div>
          <h4 class="service-card__title">Building Work</h4>
          <p class="service-card__desc">Complete building construction from foundation to finishing</p>
        </div>
        <div class="service-card animate-on-scroll">
          <div class="service-card__icon">⚙️</div>
          <h4 class="service-card__title">Fabrication</h4>
          <p class="service-card__desc">Structural steel fabrication and erection for complex structures</p>
        </div>
        <div class="service-card animate-on-scroll">
          <div class="service-card__icon">🔩</div>
          <h4 class="service-card__title">Reinforcing</h4>
          <p class="service-card__desc">Cutting, binding and fixing of reinforcement steel with precision</p>
        </div>
        <div class="service-card animate-on-scroll">
          <div class="service-card__icon">🏗️</div>
          <h4 class="service-card__title">Erection</h4>
          <p class="service-card__desc">Heavy lifting and structural erection for industrial and civil projects</p>
        </div>
        <div class="service-card animate-on-scroll">
          <div class="service-card__icon">🔌</div>
          <h4 class="service-card__title">MEP Services</h4>
          <p class="service-card__desc">Plumbing, electrical, and mechanical systems integration</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Featured Projects -->
  <section class="section">
    <div class="container">
      <span class="section-label">Featured Projects</span>
      <h2 class="section-title">Civil Works Portfolio</h2>
      <div class="grid grid--2" style="margin-top: 40px;">
        <a href="/projects/kedarnath-dham/" class="project-card animate-on-scroll" style="height: 360px;">
          <img src="/images/pdf_page_13_img_112.jpg" alt="Kedarnath Dham" class="project-card__img" />
          <div class="project-card__overlay">
            <span class="project-card__tag">Pilgrimage</span>
            <h3 class="project-card__title">Kedarnath Dham</h3>
            <p class="project-card__desc">Pilgrim Accommodation Block Q2Q at Shri Kedarnath Dham in challenging Himalayan terrain</p>
            <span class="project-card__link">View Details →</span>
          </div>
        </a>
        <a href="/projects/badrinath-dham/" class="project-card animate-on-scroll" style="height: 360px;">
          <img src="/images/pdf_page_16_img_127.jpg" alt="Badrinath Civic Center" class="project-card__img" />
          <div class="project-card__overlay">
            <span class="project-card__tag">Civic Center</span>
            <h3 class="project-card__title">Badrinath Civic Center</h3>
            <p class="project-card__desc">Civic Center Building near Badrish Lake at Shri Badrinath Dham</p>
            <span class="project-card__link">View Details →</span>
          </div>
        </a>
      </div>
    </div>
  </section>

  <!-- Other Infrastructure -->
  <section class="section section--navy">
    <div class="container">
      <span class="section-label">Infrastructure Portfolio</span>
      <h2 class="section-title" style="color: var(--white);">Executed Infrastructure Projects</h2>
      <div class="grid grid--2" style="margin-top: 30px;">
        <ul class="scope-list" style="color: rgba(255,255,255,0.8);">
          <li>Passive Fire Protection — Nagpur–Mumbai Super Expressway</li>
          <li>Raw Water Reservoir Excavation, Barmer (Rajasthan)</li>
          <li>Industrial Model Township, Rohtak (Haryana)</li>
          <li>Industrial Area Infrastructure, Bhorgrah, Bawana Site</li>
          <li>Misc Civil Works, Rajpura Thermal Power Project</li>
          <li>Site Grading — 2×700 MW Rajpura Thermal Power</li>
          <li>12 MLD & 24 MLD CETP Projects, Nagloi, Delhi</li>
        </ul>
        <ul class="scope-list" style="color: rgba(255,255,255,0.8);">
          <li>294 Km GAIL Gas Pipeline Joint Coating (Jaipur to Loni)</li>
          <li>Cement Mortar Lining, Sonya Vihar Phase I & II</li>
          <li>Railway Bridge, Nabha Power Ltd (Rajpura)</li>
          <li>Shot Blasting & Epoxy Painting, CAIRN Energy Terminal</li>
          <li>Insulation, HMEL Bhatinda Refinery</li>
          <li>PU Foam Insulation & PVC Waterproofing, AIIMS Bhopal</li>
          <li>Concrete Coating with Shotcreting — GTCL Bangladesh</li>
        </ul>
      </div>
    </div>
  </section>

  <Footer />
</BaseLayout>
