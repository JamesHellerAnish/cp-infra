---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
---

<BaseLayout title="Kedarnath Dham Project — CP Systems" description="Construction of Pilgrim Accommodation Block Q2Q at Shri Kedarnath Dham in extreme Himalayan terrain.">
  <Header />

  <div class="page-header">
    <div class="container">
      <h1 class="page-header__title">Kedarnath Dham</h1>
      <div class="page-header__breadcrumb">
        <a href="/">Home</a> <span>/</span> <a href="#">Projects</a> <span>/</span> <span>Kedarnath Dham</span>
      </div>
    </div>
  </div>

  <section class="section">
    <div class="container">
      <div class="content-block animate-on-scroll">
        <div>
          <span class="section-label">Project Overview</span>
          <h2 class="section-title">Pilgrim Accommodation at Kedarnath Dham</h2>
          <p>
            Construction of Pilgrim Accommodation Block Q2Q at Shri Kedarnath Dham — one of India's most sacred pilgrimage sites. The project demanded construction in challenging Himalayan terrain with extreme altitude and weather conditions, making it a time-sensitive and technically complex endeavor.
          </p>
          <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 16px; margin-top: 20px;">
            <div style="background: var(--beige); padding: 16px; border-radius: 8px;">
              <strong style="color: var(--navy); font-size: 0.85rem;">Category</strong><br/>
              <span>Civil & Mechanical Works</span>
            </div>
            <div style="background: var(--beige); padding: 16px; border-radius: 8px;">
              <strong style="color: var(--navy); font-size: 0.85rem;">Location</strong><br/>
              <span>Kedarnath, Uttarakhand</span>
            </div>
          </div>
        </div>
        <div class="content-block__image">
          <img src="/images/pdf_page_13_img_112.jpg" alt="Kedarnath Dham Project" />
        </div>
      </div>
    </div>
  </section>

  <section class="section section--beige">
    <div class="container">
      <span class="section-label">Scope of Work</span>
      <h2 class="section-title">Construction Activities</h2>
      <div class="grid grid--2" style="margin-top: 30px;">
        <ul class="scope-list">
          <li>Excavation</li>
          <li>Concreting</li>
          <li>Cutting, binding and fixing of reinforcement steel</li>
          <li>Formwork of structure</li>
          <li>Construction of truss using structural steel</li>
          <li>False ceiling work</li>
        </ul>
        <ul class="scope-list">
          <li>Tile, Kota, and Granite work</li>
          <li>Fixing of doors, windows and ventilators</li>
          <li>Stone cladding work</li>
          <li>Plumbing work</li>
          <li>Electrical work</li>
          <li>Painting & finishing work</li>
        </ul>
      </div>
    </div>
  </section>

  <section class="section section--navy">
    <div class="container">
      <span class="section-label">Project Gallery</span>
      <h2 class="section-title" style="color: var(--white);">Construction Progress</h2>
      <div class="grid grid--3" style="margin-top: 30px;">
        <div class="gallery-item"><img src="/images/pdf_page_13_img_113.jpg" alt="Kedarnath Construction 1" /></div>
        <div class="gallery-item"><img src="/images/pdf_page_13_img_114.jpg" alt="Kedarnath Construction 2" /></div>
        <div class="gallery-item"><img src="/images/pdf_page_13_img_115.jpg" alt="Kedarnath Construction 3" /></div>
        <div class="gallery-item"><img src="/images/pdf_page_14_img_116.jpg" alt="Kedarnath Building 1" /></div>
        <div class="gallery-item"><img src="/images/pdf_page_14_img_117.jpg" alt="Kedarnath Building 2" /></div>
        <div class="gallery-item"><img src="/images/pdf_page_14_img_118.jpg" alt="Kedarnath Building 3" /></div>
      </div>
    </div>
  </section>

  <Footer />
</BaseLayout>

<style>
  .gallery-item { border-radius: var(--radius); overflow: hidden; }
  .gallery-item img { width: 100%; height: 240px; object-fit: cover; transition: transform 0.4s ease; }
  .gallery-item:hover img { transform: scale(1.05); }
</style>
